<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <title>資工選課表 - HW2</title>
    <style>
        
        table {
            font-family: Arial, Helvetica, sans-serif;
            border-collapse: collapse;
            width: 100%;
        }
        td, th {
            border: 1px solid #ddd;
            padding: 8px;
            cursor: pointer; 
        }
        tr:nth-child(even) { background-color: #f2f2f2; }
        tr:hover { background-color: #ddd; }
        th {
            padding-top: 12px;
            padding-bottom: 12px;
            text-align: left;
            background-color: #04AA6D;
            color: white;
        }
        button {
            margin-top: 10px;
            padding: 5px 10px;
            cursor: pointer;
        }
        
        #popover {
            display: none;
            position: fixed;
            top: 20%;
            right: 10%;
            width: 300px;
            background: white;
            border: 1px solid #000;
            padding: 15px;
            box-shadow: 5px 5px 15px rgba(0,0,0,0.3);
            z-index: 100;
        }
    </style>
</head>
<body>

    <h2>資工選課表</h2>

    <table id="csie">
        <thead>
            <tr>
                <th>開課單位</th>
                <th>課程名稱</th>
                <th>授課教師</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>資工系</td>
                <td onclick="showPopover('物件導向軟體設計', 'A2337', '黃崇源')">物件導向軟體設計</td>
                <td>黃崇源</td>
            </tr>
            <tr>
                <td>資工系</td>
                <td>計算機網路實驗</td>
                <td>李春良</td>
            </tr>
            <tr>
                <td>資工系</td>
                <td>作業系統實務</td>
                <td>張哲維</td>
            </tr>
            <tr>
                <td>資工系</td>
                <td>生物統計</td>
                <td>陳光武</td>
            </tr>
            <tr>
                <td>資工系</td>
                <td>通訊系統</td>
                <td>陳仁暉</td>
            </tr>
            <tr>
                <td>資工系</td>
                <td>軟硬體專題(2)</td>
                <td>魏志達</td>
            </tr>
        </tbody>
    </table>

    <button onclick="changeResult()">Change</button>

    <div id="popover">
        <h3>課程詳細資料 <span style="font-size: 12px; cursor: pointer; float: right;" onclick="closePopover()">[關閉]</span></h3>
        <hr>
        <p><strong>課程名稱：</strong> <span id="p-name"></span></p>
        <p><strong>開課序號：</strong> <span id="p-id"></span></p>
        <p><strong>授課教師：</strong> <span id="p-teacher"></span></p>
        <p><strong>上課時間：</strong> 星期五 (09:10 - 12:00)</p>
    </div>

    <script>
        
        function changeResult() {
            var myTable = document.getElementById("csie");
            
            myTable.rows[1].cells[2].innerHTML = "李春良";
        }

        
        function showPopover(name, id, teacher) {
            document.getElementById("p-name").innerText = name;
            document.getElementById("p-id").innerText = id;
            document.getElementById("p-teacher").innerText = teacher;
            document.getElementById("popover").style.display = "block";
        }

        function closePopover() {
            document.getElementById("popover").style.display = "none";
        }
    </script>

</body>
</html>
