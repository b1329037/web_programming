from rest_framework.views import APIView
from rest_framework.response import Response
from rest_framework import status
import logging
from django.http import JsonResponse
from .models import Post, Course
from rest_framework.decorators import api_view

logger = logging.getLogger('django')

class MyHelloApi(APIView):
    def get(self, request):
        logger.info("Someone accessed the MyHello API!")
        name = request.GET.get('name', None)
        
        if name:
            return Response({"res": f"Hello {name}"}, status=status.HTTP_200_OK)
        else:
            return Response({"res": "parameter : name is None"}, status=status.HTTP_400_BAD_REQUEST)
@api_view(['GET'])
def list_post(request):
 posts = Post.objects.all().values()
 return JsonResponse(list(posts))
@api_view(['GET'])
def add_post(request):
    title = request.GET.get('title')
    content = request.GET.get('content')
    Post.objects.create(title=title, content=content)
    return JsonResponse({"data":f"{title}insert!"})
@api_view(['GET'])
def courselist(request):
    courses = Course.objects.all().values()
    return JsonResponse(list(courses))

@api_view(['GET'])
def addcourse(request):
    dept = request.GET.get('Department')
    title = request.GET.get('CourseTitle')
    instr = request.GET.get('Instructor')
    
    Course.objects.create(Department=dept, CourseTitle=title, Instructor=instr)
    return JsonResponse({"data": f"{title} insert!"})
from django.shortcuts import render

def index(request):
    return render(request, 'index.html')


